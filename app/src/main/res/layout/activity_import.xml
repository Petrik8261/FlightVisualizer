<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Import dát"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnPickFile"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Vybrať súbor (KML / TXT / CSV)"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Vyber súbor s letovým záznamom.\nPo načítaní zobrazíme, čo sa podarilo detekovať."
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnPickFile"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <TextView
        android:id="@+id/tvSelectedLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Vybraný súbor:"
        android:textStyle="bold"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/tvInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvSelectedFile"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="(žiadny)"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvSelectedLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <Button
        android:id="@+id/btnClearSelection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Vymazať výber"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvSelectedFile"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnBackToDevice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="SPÄŤ NA VÝBER ZARIADENIA"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnExitImport"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="KONIEC"
        android:backgroundTint="#B00020"
        android:textColor="@android:color/white"
        android:layout_margin="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


</androidx.constraintlayout.widget.ConstraintLayout>

