<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#0E1733"
            app:titleTextColor="@android:color/white" />

        <!-- Hlavička -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="28dp"
            android:paddingBottom="20dp"
            android:paddingHorizontal="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FlightVisualizer"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#B8C0D8"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Popis -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingBottom="6dp"
            android:text="Popis"
            android:textColor="#F4C10F"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingBottom="10dp"
            android:textColor="#D0D8EC"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.5"
            android:text="Aplikácia zobrazuje letové záznamy na satelitnej mape a vizualizuje letové parametre prostredníctvom syntetického displeja letu (HUD). Podporuje záznamy z avioniky všeobecného letectva, leteckých simulátorov, rekreačných dronov aj vlastných zariadení." />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingBottom="16dp"
            android:textColor="#D0D8EC"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.5"
            android:text="Pred prehrávaním sa zobrazí prehľad dostupných veličín. Podľa obsahu záznamu sa automaticky zvolí režim HUD: plný (FULL), obmedzený (LIMITED) alebo trajektórový (TRAJECTORY)." />

        <!-- Separator -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginStart="20dp" android:layout_marginEnd="20dp" android:layout_marginBottom="16dp"
            android:background="#1E2A4A" />

        <!-- Podporované formáty — nadpis -->
