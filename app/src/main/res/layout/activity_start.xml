<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingEnd="18dp"
    android:paddingTop="24dp"
    android:paddingBottom="18dp"
    android:background="#000000">

    <!-- Title (center, ako úvodná) -->
    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:text="@string/app_name"
        android:textSize="40sp"
        android:textStyle="normal"
        android:gravity="center"
        android:textColor="#FFFFFF" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Import dát"
        android:textSize="18sp"
        android:gravity="center"
        android:textColor="#BDBDBD" />

    <!-- Button: Vybrať súbor (štýl z importu, farby ako intro) -->
    <Button
        android:id="@+id/btnPickFile"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="28dp"
        android:text="VYBRAŤ SÚBOR (KML / TXT / CSV)"
        android:textAllCaps="true"
        android:textStyle="bold"
        android:textColor="#000000"
        android:backgroundTint="#FFC107" />

    <!-- Popis ako v importe -->
    <TextView
        android:id="@+id/tvHelp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="Vyber súbor s letovým záznamom.\nPo načítaní zobrazíme, čo sa podarilo detekovať."
        android:textSize="16sp"
        android:textColor="#E0E0E0" />

    <!-- Vybraný súbor -->
    <TextView
        android:id="@+id/tvSelectedLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:text="Vybraný súbor:"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF" />

    <TextView
        android:id="@+id/tvSelectedFile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="(žiadny)"
        android:textSize="16sp"
        android:textColor="#BDBDBD" />

    <!-- Vymazať výber (šedé ako LIETADLO z úvodnej) -->
    <Button
        android:id="@+id/btnClearSelection"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="18dp"
        android:text="VYMAZAŤ VÝBER"
        android:textAllCaps="true"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#616161" />

    <!-- Spacer aby KONIEC bolo úplne dole -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- KONIEC dole (červené ako pôvodne) -->
    <Button
        android:id="@+id/btnExit"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="KONIEC"
        android:textAllCaps="true"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#B00020" />

</LinearLayout>